# Local dev: a plain file works. Production: use your Turso values.
DATABASE_URL="file:./prisma/dev.db"
# For Turso (production), instead use:
# DATABASE_URL="libsql://<your-db>.turso.io"
# DATABASE_AUTH_TOKEN="<your-turso-token>"

# Auth — REQUIRED for the admin panel.
# NEXTAUTH_SECRET: generate with `openssl rand -base64 32`
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
# NEXTAUTH_URL: your site URL. Locally this; on Vercel set to the deployed URL.
NEXTAUTH_URL="http://localhost:3000"
